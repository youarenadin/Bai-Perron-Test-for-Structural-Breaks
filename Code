library(zoo)
library("strucchange")
library(tseries)
library(readxl)

data <- read_excel("dataforR.xlsx")

# ИНФЛЯЦИЯ

df_p <- data.frame(
  p = as.numeric(data$p),
  trend = 1:nrow(data)
)

p_BP <- breakpoints(p ~ trend, data = df_p, h = 8) # минимальное количество наблюдений между сдвигами. 8, т.к. это 0,1 * 80 (по рекомендации из работы Bai, Perron (1998) - можно брать от 0,05 до 0,15)
p_BP
plot(p_BP)
confint(p_BP)


