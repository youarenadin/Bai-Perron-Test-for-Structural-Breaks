# ДЛЯ ВСЕЙ СИСТЕМЫ

df <- data.frame(
  CPI          = as.numeric(data$CPI),
  ICP          = as.numeric(data$ICP),
  iMOEX        = as.numeric(data$iMOEX),
  KeyRate      = as.numeric(data$KeyRate),
  M2           = as.numeric(data$M2),
  IPP          = as.numeric(data$IPP),
  BusinessClim = as.numeric(data$BusinessClim),
  Retail       = as.numeric(data$Retail),
  Budget       = as.numeric(data$Budget),
  Unempl       = as.numeric(data$Unempl),
  REER         = as.numeric(data$REER),
  Urals        = as.numeric(data$Urals),
  EU           = as.numeric(data$EU)
)


endo_vars <- c("CPI", "ICP", "iMOEX", "KeyRate", "M2",
               "IPP", "BusinessClim", "Retail", "Budget", "Unempl")

exo_vars  <- c("REER", "Urals", "EU")

n_lags <- 4


# Создаем лаги 1...6 для всех эндогенных переменных

for (v in endo_vars) {
  for (L in 1:n_lags) {
    df[[paste0(v, "_l", L)]] <- c(rep(NA, L), head(df[[v]], -L))
  }
}

# убираем первые 6 строк, где лаги не определены
df_var <- na.omit(df)


# Формируем уравнение для инфляции

rhs_lags <- unlist(
  lapply(endo_vars, function(v) paste0(v, "_l", 1:n_lags))
)

rhs_all <- c(rhs_lags, exo_vars)

form_CPI <- as.formula(
  paste("CPI ~", paste(rhs_all, collapse = " + "))
)


bp_CPI <- breakpoints(
  form_CPI,
  data = df_var,
  h = 55
)

bp_CPI
plot(bp_CPI)
confint(bp_CPI)


bp_Y <- breakpoints(
  Y ~ p_l1 + p_l2 + Y_l1 + Y_l2 + i_l1 + i_l2 + B_l1 + B_l2 + poil,
  data = df_var,
  h = 12
)

bp_Y
plot(bp_Y)
confint(bp_Y)


bp_i <- breakpoints(
